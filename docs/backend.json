{
  "entities": {
    "Attendance": {
      "title": "Attendance",
      "type": "object",
      "description": "Daily work record including clock-in/out, breaks, and idle time tracking.",
      "properties": {
        "orgId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "clockIn": { "type": "string", "format": "date-time" },
        "clockOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "location": { "type": "string", "enum": ["OFFICE", "REMOTE"] },
        "idleTime": { "type": "number", "description": "Total idle seconds detected." },
        "totalBreak": { "type": "number", "description": "Total break seconds." },
        "onBreak": { "type": "boolean" },
        "breaks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time" },
              "end": { "type": "string", "format": "date-time" }
            }
          }
        },
        "remarks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "A delegated mission or project unit.",
      "properties": {
        "orgId": { "type": "string" },
        "serialNo": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "assignedToName": { "type": "string" },
        "priority": { "type": "string", "enum": ["LEVEL_1", "LEVEL_2", "LEVEL_3"] },
        "status": { "type": "string", "enum": ["QUEUED", "ACTIVE", "AWAITING_REVIEW", "ARCHIVED"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "workbookId": { "type": "string" },
        "sheetId": { "type": "string" },
        "subTasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      }
    },
    "Vendor": {
      "title": "Vendor",
      "type": "object",
      "description": "Represents an external supplier or service provider.",
      "properties": {
        "orgId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isActive": { "type": "boolean" }
      }
    },
    "PurchaseOrder": {
      "title": "Purchase Order",
      "type": "object",
      "properties": {
        "serialNo": { "type": "string" },
        "orgId": { "type": "string" },
        "vendorName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["DRAFT", "SENT", "DELIVERED", "CANCELLED"] }
      }
    },
    "Account": {
      "title": "Account",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "balance": { "type": "number" }
      }
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "POSTED"] },
        "lines": { "type": "array", "items": { "type": "object" } }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "The primary user identity within the organization.",
      "properties": {
        "orgId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string", "description": "Unique organizational identifier." },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string", "nullable": true },
        "avatarUrl": { "type": "string", "nullable": true },
        "role": { "type": "string", "enum": ["ORG_ADMIN", "MANAGING_DIRECTOR", "HR_MANAGER", "FINANCE_MANAGER", "STAFF"] },
        "position": { "type": "string" },
        "departmentName": { "type": "string" },
        "joinedDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ONLINE", "OFFLINE", "ON_LEAVE"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "email", "fullName", "role", "username", "joinedDate"]
    }
  },
  "auth": { "providers": ["password"] },
  "firestore": {
    "structure": [
      { "path": "/attendance/{id}", "definition": { "entityName": "Attendance", "schema": { "$ref": "#/entities/Attendance" } } },
      { "path": "/tasks/{id}", "definition": { "entityName": "Task", "schema": { "$ref": "#/entities/Task" } } },
      { "path": "/vendors/{id}", "definition": { "entityName": "Vendor", "schema": { "$ref": "#/entities/Vendor" } } },
      { "path": "/purchase_orders/{id}", "definition": { "entityName": "PurchaseOrder", "schema": { "$ref": "#/entities/PurchaseOrder" } } },
      { "path": "/accounts/{id}", "definition": { "entityName": "Account", "schema": { "$ref": "#/entities/Account" } } },
      { "path": "/journal_entries/{id}", "definition": { "entityName": "JournalEntry", "schema": { "$ref": "#/entities/JournalEntry" } } },
      { "path": "/users/{id}", "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/entities/UserProfile" } } }
    ]
  }
}
