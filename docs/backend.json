{
  "entities": {
    "Vendor": {
      "title": "Vendor",
      "type": "object",
      "description": "Represents an external supplier or service provider.",
      "properties": {
        "orgId": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number", "minimum": 0, "maximum": 5 },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orgId", "name", "email", "isActive"]
    },
    "PurchaseOrder": {
        "title": "Purchase Order",
        "type": "object",
        "description": "A formal order sent to a vendor for goods or services.",
        "properties": {
            "serialNo": { "type": "string" },
            "orgId": { "type": "string" },
            "vendorId": { "type": "string" },
            "vendorName": { "type": "string" },
            "requisitionId": { "type": "string" },
            "title": { "type": "string" },
            "totalAmount": { "type": "number" },
            "status": { "type": "string", "enum": ["DRAFT", "SENT", "DELIVERED", "CANCELLED"] },
            "items": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "description": { "type": "string" },
                        "quantity": { "type": "number" },
                        "unitPrice": { "type": "number" },
                        "total": { "type": "number" }
                    }
                }
            },
            "createdAt": { "type": "string", "format": "date-time" },
            "createdBy": { "type": "string" }
        }
    },
    "Account": {
      "title": "Account",
      "type": "object",
      "description": "Represents a single account in the Chart of Accounts.",
      "properties": {
        "orgId": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["ASSET", "LIABILITY", "EQUITY", "REVENUE", "EXPENSE"] },
        "category": { "type": "string" },
        "balance": { "type": "number" },
        "isDebitNormal": { "type": "boolean" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["orgId", "name", "code", "type", "category", "balance", "isDebitNormal", "isActive"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "type": "object",
      "description": "A financial transaction record.",
      "properties": {
        "orgId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "reference": { "type": "string" },
        "status": { "type": "string", "enum": ["DRAFT", "POSTED"] },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "accountId": { "type": "string" },
              "accountName": { "type": "string" },
              "debit": { "type": "number" },
              "credit": { "type": "number" }
            }
          }
        }
      },
      "required": ["orgId", "date", "description", "status", "createdBy", "lines"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "orgId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["ORG_ADMIN", "MANAGING_DIRECTOR", "HR_MANAGER", "FINANCE_MANAGER", "STAFF"] },
        "position": { "type": "string" },
        "joinedDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": { "providers": [] },
  "firestore": {
    "structure": [
      { "path": "/vendors/{vendorId}", "definition": { "entityName": "Vendor", "schema": { "$ref": "#/entities/Vendor" } } },
      { "path": "/purchase_orders/{poId}", "definition": { "entityName": "PurchaseOrder", "schema": { "$ref": "#/entities/PurchaseOrder" } } },
      { "path": "/accounts/{accountId}", "definition": { "entityName": "Account", "schema": { "$ref": "#/entities/Account" } } },
      { "path": "/journal_entries/{entryId}", "definition": { "entityName": "JournalEntry", "schema": { "$ref": "#/entities/JournalEntry" } } },
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/entities/UserProfile" } } }
    ]
  }
}
