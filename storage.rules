rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isUserInOrg(orgId) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId;
    }

    match /requisitions/{orgId}/{fileName} {
      allow read, write: if isUserInOrg(orgId);
    }

    match /tasks/{orgId}/{fileName} {
      allow read, write: if isUserInOrg(orgId);
    }

    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

    