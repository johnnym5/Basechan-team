rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helper Functions =====
    
    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'jegbase@gmail.com' || request.auth.uid == 'nM0bBwaybEQP95OPKUyQ97iAm3u2');
    }

    function getUserData() {
      // Hardened check for profile existence to prevent rule evaluation crashes
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : {"role": "STAFF", "orgId": "none"};
    }

    function getUserOrgId() {
      return getUserData().orgId;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isRequestingUserInOrg(docOrgId) {
      return request.auth != null && (isSuperAdmin() || getUserOrgId() == docOrgId);
    }

    function isCreatingInOwnOrg() {
      return request.auth != null && (isSuperAdmin() || getUserOrgId() == request.resource.data.orgId);
    }

    function isHRManager() {
        return getUserRole() in ['HR_MANAGER', 'ORG_ADMIN'];
    }

    function isFinanceManager() {
        return getUserRole() in ['FINANCE_MANAGER', 'ORG_ADMIN'];
    }

    function isManagingDirector() {
        return getUserRole() in ['MANAGING_DIRECTOR', 'ORG_ADMIN'];
    }

    function isAdmin() {
        return getUserRole() in ['ORG_ADMIN', 'MANAGING_DIRECTOR', 'HR_MANAGER'];
    }

    function hasCustomPermission(perm) {
      let data = getUserData();
      return 'customPermissions' in data && 
             perm in data.customPermissions && 
             data.customPermissions[perm] == true;
    }
    
    // ===== Root Collections =====

    match /organizations/{orgId} {
      allow read: if isRequestingUserInOrg(orgId);
      allow write: if isSuperAdmin();
    }

    match /accounts/{accountId} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if (isFinanceManager() || isSuperAdmin()) && isRequestingUserInOrg(request.resource.data.orgId);
    }

    match /vendors/{vendorId} {
        allow read: if isRequestingUserInOrg(resource.data.orgId);
        allow write: if isAdmin() || isSuperAdmin();
    }

    match /purchase_orders/{poId} {
        allow read: if isRequestingUserInOrg(resource.data.orgId);
        allow create: if isManagingDirector() || isFinanceManager() || isSuperAdmin();
        allow update: if isFinanceManager() || isManagingDirector() || isSuperAdmin();
        allow delete: if isSuperAdmin();
    }

    match /requisitions/{reqId} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow create: if isCreatingInOwnOrg() || isSuperAdmin();
      
      allow update: if isSuperAdmin() || (isRequestingUserInOrg(resource.data.orgId) && (
        (request.resource.data.status == 'PENDING_FINANCE' && isHRManager()) ||
        (request.resource.data.status == 'PENDING_MD' && isFinanceManager()) ||
        (request.resource.data.status == 'APPROVED' && isManagingDirector()) ||
        (request.resource.data.status == 'PAID' && isFinanceManager()) ||
        (request.resource.data.status == 'REJECTED' && (isHRManager() || isFinanceManager() || isManagingDirector())) ||
        (request.auth.uid == resource.data.createdBy && resource.data.status == 'PENDING_HR')
      ));
    }

    match /users/{userId} {
      // Allow public read for login ID verification (unauthenticated username/email lookup)
      // and for authenticated users to read any profile (needed for org-wide features)
      allow read: if true;
      allow create: if isSuperAdmin() || request.auth.uid == userId;
      allow update: if isSuperAdmin() || request.auth.uid == userId || isHRManager();
      allow delete: if isSuperAdmin();
      
      match /telemetry/{docId} {
          allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin() || (isAdmin() && isRequestingUserInOrg(getUserOrgId())));
          
          match /{allSubcollections=**} {
              allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin() || (isAdmin() && isRequestingUserInOrg(getUserOrgId())));
          }
      }
    }
    
    match /notifications/{id} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isSuperAdmin() || isAdmin());
      allow write: if isRequestingUserInOrg(request.resource.data.orgId) || isSuperAdmin();
    }

    match /external_displays/{displayId} {
      allow read: if isRequestingUserInOrg(resource.data.orgId) && 
                 (!('displayMode' in resource.data) || resource.data.displayMode == 'GLOBAL' || resource.data.createdBy == request.auth.uid || isSuperAdmin());
      allow create: if isCreatingInOwnOrg() && (
        (request.resource.data.displayMode == 'GLOBAL' && (getUserRole() in ['ORG_ADMIN', 'MANAGING_DIRECTOR'] || isSuperAdmin())) ||
        (request.resource.data.displayMode == 'PRIVATE' && request.resource.data.createdBy == request.auth.uid) ||
        // Fallback for older code without displayMode
        (!('displayMode' in request.resource.data) && (getUserRole() in ['ORG_ADMIN', 'MANAGING_DIRECTOR'] || isSuperAdmin()))
      );
      allow update, delete: if isRequestingUserInOrg(resource.data.orgId) && (
        (!('displayMode' in resource.data) && (getUserRole() in ['ORG_ADMIN', 'MANAGING_DIRECTOR'] || isSuperAdmin())) ||
        (resource.data.displayMode == 'GLOBAL' && (getUserRole() in ['ORG_ADMIN', 'MANAGING_DIRECTOR'] || isSuperAdmin())) ||
        (resource.data.displayMode == 'PRIVATE' && resource.data.createdBy == request.auth.uid)
      );
    }

    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, write: if isSuperAdmin();
    }
    
    match /error_logs/{errorId} {
      allow create: if true;
      allow read, write: if isSuperAdmin();
    }

    match /workbooks/{workbookId}/sheets/{sheetId} {
      allow read, write: if isSuperAdmin() || isRequestingUserInOrg(get(/databases/$(database)/documents/workbooks/$(workbookId)).data.orgId);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSuperAdmin() || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isSuperAdmin() || (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && request.resource.data.senderId == request.auth.uid);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin() || (
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
        resource.data.timestamp < (request.time - duration.value(24, 'h'))
      );
    }

    // ===== Specific Roles & Custom Permission aware Rules =====

    match /departments/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isSuperAdmin() || (isRequestingUserInOrg(request.resource.data.orgId) && (isAdmin() || isHRManager() || isManagingDirector()));
    }

    match /attendance/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isRequestingUserInOrg(request.resource.data.orgId);
    }

    match /tasks/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId) && (
        getUserRole() != 'STAFF' || 
        resource.data.createdBy == request.auth.uid || 
        resource.data.assigneeId == request.auth.uid || 
        hasCustomPermission('canAccessAllTasks')
      );
      allow create: if isCreatingInOwnOrg() || isSuperAdmin();
      allow update, delete: if isRequestingUserInOrg(resource.data.orgId);
    }

    match /system_configs/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isSuperAdmin() || (isRequestingUserInOrg(request.resource.data.orgId) && getUserRole() == 'ORG_ADMIN');
    }

    match /announcements/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isSuperAdmin() || (isRequestingUserInOrg(request.resource.data.orgId) && (isAdmin() || hasCustomPermission('canManageAnnouncements')));
    }

    match /workbooks/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId) && (
        getUserRole() != 'STAFF' || 
        hasCustomPermission('canAccessAllWorkbooks')
      );
      allow create: if isCreatingInOwnOrg() || isSuperAdmin();
      allow update, delete: if isSuperAdmin() || (isRequestingUserInOrg(resource.data.orgId) && (isAdmin() || hasCustomPermission('canAccessAllWorkbooks')));
    }

    match /rosters/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isSuperAdmin() || (isRequestingUserInOrg(request.resource.data.orgId) && (isHRManager() || isManagingDirector()));
    }

    match /library_items/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId) && (
        getUserRole() != 'STAFF' || 
        hasCustomPermission('canAccessLibrary')
      );
      allow write: if isSuperAdmin() || (isRequestingUserInOrg(request.resource.data.orgId) && (isAdmin() || hasCustomPermission('canManageLibrary')));
    }

    match /leave_requests/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow create: if isCreatingInOwnOrg() || isSuperAdmin();
      allow update: if isRequestingUserInOrg(resource.data.orgId) && (
        isHRManager() || 
        isManagingDirector() || 
        resource.data.userId == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    match /daily_reports/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow create: if isCreatingInOwnOrg() || isSuperAdmin();
      allow update: if isRequestingUserInOrg(resource.data.orgId) && (
        isAdmin() || 
        resource.data.createdBy == request.auth.uid
      );
      allow delete: if isSuperAdmin();
    }

    match /journal_entries/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isSuperAdmin() || (isRequestingUserInOrg(request.resource.data.orgId) && (isFinanceManager() || hasCustomPermission('canManageAccounting')));
    }

    match /pulse_checks/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isRequestingUserInOrg(request.resource.data.orgId);
    }

    match /activity_points/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isSuperAdmin() || (isRequestingUserInOrg(request.resource.data.orgId) && isAdmin());
    }

    match /kudos/{id} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow create: if isCreatingInOwnOrg() || isSuperAdmin();
      allow update, delete: if isSuperAdmin() || (isRequestingUserInOrg(resource.data.orgId) && resource.data.createdBy == request.auth.uid);
    }

    // Generic fallback for any unhandled core collection, ensuring basic multi-tenant isolation
    match /{collection}/{docId} {
      allow read, delete, update: if isRequestingUserInOrg(resource.data.orgId) || isSuperAdmin();
      allow create: if isCreatingInOwnOrg() || isSuperAdmin();
    }
  }
}