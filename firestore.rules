
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helper Functions =====
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserOrgId() {
      return getUserData().orgId;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isRequestingUserInOrg(docOrgId) {
      return request.auth != null && getUserOrgId() == docOrgId;
    }

    function isCreatingInOwnOrg() {
      return request.auth != null && getUserOrgId() == request.resource.data.orgId;
    }

    function isHRManager() {
        return getUserRole() in ['HR_MANAGER', 'ORG_ADMIN'];
    }

    function isFinanceManager() {
        return getUserRole() in ['FINANCE_MANAGER', 'ORG_ADMIN'];
    }

    function isManagingDirector() {
        return getUserRole() in ['MANAGING_DIRECTOR', 'ORG_ADMIN'];
    }
    
    // ===== Root Collections =====

    match /accounts/{accountId} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow write: if isFinanceManager() && isRequestingUserInOrg(resource.data.orgId);
    }

    match /vendors/{vendorId} {
        allow read: if isRequestingUserInOrg(resource.data.orgId);
        allow write: if isHRManager() || isFinanceManager() || isManagingDirector();
    }

    match /purchase_orders/{poId} {
        allow read: if isRequestingUserInOrg(resource.data.orgId);
        allow create: if isManagingDirector() || isFinanceManager();
        allow update: if isFinanceManager() || isManagingDirector();
        allow delete: if false;
    }

    match /requisitions/{reqId} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow create: if isCreatingInOwnOrg();
      
      // Approval workflow enforcement
      allow update: if isRequestingUserInOrg(resource.data.orgId) && (
        (request.resource.data.status == 'PENDING_FINANCE' && isHRManager()) ||
        (request.resource.data.status == 'PENDING_MD' && isFinanceManager()) ||
        (request.resource.data.status == 'APPROVED' && isManagingDirector()) ||
        (request.resource.data.status == 'PAID' && isFinanceManager()) ||
        (request.resource.data.status == 'REJECTED' && (isHRManager() || isFinanceManager() || isManagingDirector())) ||
        (request.auth.uid == resource.data.createdBy && resource.data.status == 'PENDING_HR')
      );
    }

    // User Profiles: Anyone in the org can read, but only the user can edit their own profile.
    match /users/{userId} {
      allow read: if isRequestingUserInOrg(resource.data.orgId);
      allow create: if isCreatingInOwnOrg();
      allow update: if request.auth.uid == userId || isHRManager();
      allow delete: if false;
    }
    
    // Generic rule for collections with an orgId field.
    match /{collection}/{docId} 
        where collection in ['departments', 'attendance', 'tasks', 'system_configs', 'announcements', 'workbooks', 'notifications', 'leave_requests', 'daily_reports', 'chats', 'journal_entries'] {
      
      allow read, delete: if isRequestingUserInOrg(resource.data.orgId);
      allow create: if isCreatingInOwnOrg();
      allow update: if isRequestingUserInOrg(resource.data.orgId);
    }

    match /feedback/{feedbackId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /error_logs/{errorId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ===== Subcollections =====

    match /workbooks/{workbookId}/sheets/{sheetId} {
      allow read, write: if isRequestingUserInOrg(get(/databases/$(database)/documents/workbooks/$(workbookId)).data.orgId);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
